<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome layer for Android 13+ themed icons. Single-colour line art; the
  launcher tints it. Devices are drawn as outlines so the overlapping pair stays
  legible when flattened to one colour. Geometry matches the foreground.
-->
