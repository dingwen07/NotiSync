<?xml version="1.0" encoding="utf-8"?>
<!--
  Locales offered in the system per-app language picker. We ship resources for en (default) and
  zh-CN; the remaining locales are filled in automatically by Google Play's on-device translation
  (Gemini) at the bundle level. They are listed here so the picker shows every supported language
  even though their res/values-* folders are not present in source.
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="zh-CN" />
    <locale android:name="fr" />
    <locale android:name="de" />
    <locale android:name="ja" />
    <locale android:name="ko" />
    <locale android:name="ru" />
</locale-config>
