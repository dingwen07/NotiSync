{
  "sourceLanguage" : "en",
  "strings" : {
    "“My device” shares notifications, dismissals, and trust. “Someone else’s” only syncs their name." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“我的设备”会共享通知、关闭操作和信任关系；“他人的设备”只同步其名称。"
          }
        }
      }
    },
