<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- No request/notification bodies are ever logged: the broker is E2E-blind. -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{30} %X{callId} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="org.jetbrains.exposed" level="WARN"/>
    <logger name="io.ktor.server.Application" level="INFO"/>
</configuration>
